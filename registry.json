{
  "$schema": "https://registry.getarcane.app/registry.json",
  "name": "Jim BENNA's ArcaneAPP Templates Registry on github",
  "description": "This is my own registry of docker-compose files to be used with Arcane-app. Enabling me to share this easily outside of my LAN",
  "version": "0.0.2",
  "author": "Jim BENNA",
  "url": "https://github.com/JimBenna/arcane-templates",
  "templates": [
    {
      "id": "JB-Owntone-docker",
      "name": "Owntone",
      "description": "OwnTone is an open source (audio) media server for GNU/Linux, FreeBSD and macOS.",
      "version": "29.2",
      "author": "ejurgensen",
      "compose_url": "https://raw.githubusercontent.com/JimBenna/arcane-templates/main/owntone/docker-compose.yml",
      "env_url": "https://raw.githubusercontent.com/JimBenna/arcane-templates/main/owntone/.env.example",
      "documentation_url": "https://owntone.github.io/owntone-server/getting-started/",
      "tags": ["media", "server"]
    },
    {
      "id": "JB-Arcane-Server",
      "name": "Arcane Server",
      "description": "Arcane Server to manage containers",
      "version": "2.4.0",
      "author": "Arcane Team",
      "compose_url": "https://raw.githubusercontent.com/JimBenna/arcane-templates/main/arcane-srv/docker-compose.yml",
      "env_url": "https://raw.githubusercontent.com/JimBenna/arcane-templates/main/arcane-srv/.env.example",
      "documentation_url": "https://getarcane.app/docs",
      "tags": ["container", "server", "docker"]
    },
    {
      "id": "JB-Arcane-Headless",
      "name": "Arcane Headless",
      "description": "Arcane client to manage locally installed containers. This version have to be linked to the server with a special token generated on the server",
      "version": "2.4.0",
      "author": "Arcane Team",
      "compose_url": "https://raw.githubusercontent.com/JimBenna/arcane-templates/main/arcane-headless/docker-compose.yml",
      "env_url": "https://raw.githubusercontent.com/JimBenna/arcane-templates/main/arcane-headless/.env.example",
      "documentation_url": "https://getarcane.app/docs",
      "tags": ["container", "server", "docker"]
    },
    {
      "id": "JB-Chromium-Headless",
      "name": "Chromium in a Container",
      "description": "Chromium without Human interaction",
      "version": "89",
      "author": "Chromium Team",
      "compose_url": "https://raw.githubusercontent.com/JimBenna/arcane-templates/main/chromium-headless/docker-compose.yml",
      "env_url": "https://raw.githubusercontent.com/JimBenna/arcane-templates/main/chromium-headless/.env.example",
      "documentation_url": "https://www.chromium.org/Home/",
      "tags": ["browser", "AI", "docker"]
    },    
    {
      "id": "JB-Forgejo-and-Postgresql",
      "name": "Forgejo",
      "description": "Beyond coding. We forge.",
      "version": "15",
      "author": "Codeberg Team",
      "compose_url": "https://raw.githubusercontent.com/JimBenna/arcane-templates/main/forgejo/docker-compose.yml",
      "env_url": "https://raw.githubusercontent.com/JimBenna/arcane-templates/main/forgejo/.env.example",
      "documentation_url": "https://forgejo.org/docs/latest/",
      "tags": ["coding", "server", "git"]
    }
  ]
}
